PORT=3000
DATABASE=mongodb://127.0.0.1:27017/crowdfunding
FRONTEND_URL=http://localhost:5173

# Required
JWT_ACCESS_SECRET=change-me-to-a-long-random-string

# Optional (if empty, backend may reuse access secret in dev)
JWT_REFRESH_SECRET=

# Required for /internal/* (n8n/cron)
INTERNAL_API_SECRET=change-me-internal-secret-for-n8n

# Redis (BullMQ). If not set, queue integrations fall back to stub mode.
REDIS_URL=redis://127.0.0.1:6379

# Gemini (chatbot + risk analysis)
GEMINI_API_KEY=change-me
# Optional: pin model id/alias to avoid future deprecations.
GEMINI_MODEL=gemini-flash-latest

# Email (Gmail SMTP example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change-me@gmail.com
SMTP_PASS=change-me
MAIL_FROM="FinCollab <change-me@gmail.com>"

# Optional
# API_RATE_LIMIT_MAX=400
# BANK_DETAILS_ENC_KEY=
# MOCK_PAYMENT_WEBHOOK_SECRET=dev-mock-secret

