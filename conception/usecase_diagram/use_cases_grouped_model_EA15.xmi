<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.5"
         xmlns:xmi="http://www.omg.org/spec/XMI/20131001"
         xmlns:uml="http://www.omg.org/spec/UML/20131001">
  <uml:Model xmi:id="m_root_grouped_ea15" name="Identification_cas_utilisation">
    <packagedElement xmi:type="uml:Package" xmi:id="pkg_uc_grouped_ea15" name="Cas_d_utilisation">

      <packagedElement xmi:type="uml:Package" xmi:id="pkg_uc_grouped_actors_ea15" name="Acteurs">
        <packagedElement xmi:type="uml:Actor" xmi:id="act_visiteur_g2" name="Visiteur"/>
        <packagedElement xmi:type="uml:Actor" xmi:id="act_utilisateur_g2" name="Utilisateur"/>
        <packagedElement xmi:type="uml:Actor" xmi:id="act_admin_g2" name="Administrateur"/>
        <packagedElement xmi:type="uml:Actor" xmi:id="act_pay_g2" name="Passerelle_de_paiement_(mock)"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Package" xmi:id="pkg_uc_grouped_usecases_ea15" name="Use_Cases">
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_auth_g2" name="S'authentifier"/>

        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_account_g2" name="Gérer mon compte"/>
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_discover_g2" name="Découvrir les projets"/>
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_manage_projects_g2" name="Gérer mes projets"/>
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_manage_contrib_g2" name="Gérer mes contributions"/>
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_manage_payouts_g2" name="Gérer mes retraits"/>
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_interact_g2" name="Interagir avec un projet"/>

        <!-- Admin minimal set -->
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_admin_projects_g2" name="Gérer les projets (admin)"/>
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_admin_users_g2" name="Gérer les utilisateurs (admin)"/>
        <packagedElement xmi:type="uml:UseCase" xmi:id="uc_admin_payouts_g2" name="Approuver les retraits (admin)"/>
      </packagedElement>

    </packagedElement>

  </uml:Model>
</xmi:XMI>

