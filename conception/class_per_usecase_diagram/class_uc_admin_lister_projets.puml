@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Gérer projets » (admin : liste)
' Alignement : `backend/routes/api/adminRoutes.js`, `backend/services/adminProjectService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Admin : lister projets »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class AdminRoutes <<controller>> {
  +GET /api/admin/projects(status?, limit?)
}

class RequireAdmin <<middleware>> {
  +requireAdmin()
}

class AdminProjectService <<service>> {
  +listAdminProjects({ status?, limit? })
}

class Project <<model>> {
  +status
  +title
}

AdminRoutes ..> RequireAdmin
AdminRoutes ..> AdminProjectService
AdminProjectService ..> Project

@enduml
