@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Récupérer mot de passe »
' Alignement : `backend/routes/api/authRoutes.js`, `backend/services/authService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Récupérer mot de passe »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class AuthRoutes <<controller>> {
  +POST /api/auth/forgot-password(email)
  +POST /api/auth/reset-password(token, password)
}

class AuthService <<service>> {
  +requestPasswordReset(email)
  +resetPasswordWithToken(token, password)
}

class User <<model>> {
  +email
  +passwordHash
  +resetTokenHash
  +resetTokenExpiry
}

class EmailUtil <<util>> {
  +sendMail(...)
}

AuthRoutes ..> AuthService
AuthService ..> User
AuthService ..> EmailUtil

note bottom of User
  Jeton de réinitialisation : stocké en hash,\n
  durée limitée (resetTokenExpiry).
end note

@enduml
