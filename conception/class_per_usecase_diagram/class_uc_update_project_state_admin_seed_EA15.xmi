<?xml version="1.0" encoding="UTF-8"?>
<xmi:XMI xmi:version="2.5"
         xmlns:xmi="http://www.omg.org/spec/XMI/20131001"
         xmlns:uml="http://www.omg.org/spec/UML/20131001">
  <!--
    Classes participantes — UC_Suspendre_ou_Reactiver_Projet_(Admin)
    Alignement : modele_domaine_global_FSEG_classes_only_EA15.xmi + conception/sequence_diagram/suspendre_reactiver_projet.txt (entités Projet, Retrait/Payout, Notification ; externe Orchestrateur_Analyse_Risque).
    Harmonisation inter-UC : mêmes attributs métier pour Utilisateur, UserProfile, Projet (y compris aiAnalysis), Payout, Notification — pas d'attributs techniques (hash, jetons, secrets).
  -->
  <uml:Model xmi:id="m_class_uc_suspend" name="Classes_Participantes_UC_Suspendre_Reactiver_Projet">
    <packagedElement xmi:type="uml:PrimitiveType" xmi:id="ucu_pt_String" name="String"/>
    <packagedElement xmi:type="uml:PrimitiveType" xmi:id="ucu_pt_Number" name="Number"/>
    <packagedElement xmi:type="uml:PrimitiveType" xmi:id="ucu_pt_Boolean" name="Boolean"/>
    <packagedElement xmi:type="uml:PrimitiveType" xmi:id="ucu_pt_Date" name="Date"/>
    <packagedElement xmi:type="uml:PrimitiveType" xmi:id="ucu_pt_ObjectId" name="ObjectId"/>

    <packagedElement xmi:type="uml:Package" xmi:id="ucu_pkg_types" name="Types">
      <packagedElement xmi:type="uml:Enumeration" xmi:id="ucu_en_StatutProjet" name="StatutProjet">
        <ownedLiteral xmi:id="ucu_lit_sp_draft" name="DRAFT"/>
        <ownedLiteral xmi:id="ucu_lit_sp_await_ai" name="AWAITING_AI"/>
        <ownedLiteral xmi:id="ucu_lit_sp_under_review" name="UNDER_REVIEW"/>
        <ownedLiteral xmi:id="ucu_lit_sp_approved" name="APPROVED"/>
        <ownedLiteral xmi:id="ucu_lit_sp_active" name="ACTIVE"/>
        <ownedLiteral xmi:id="ucu_lit_sp_rejected" name="REJECTED"/>
        <ownedLiteral xmi:id="ucu_lit_sp_funded" name="FUNDED"/>
        <ownedLiteral xmi:id="ucu_lit_sp_closed" name="CLOSED"/>
        <ownedLiteral xmi:id="ucu_lit_sp_suspended" name="SUSPENDED"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="ucu_en_RoleUtilisateur" name="RoleUtilisateur">
        <ownedLiteral xmi:id="ucu_lit_role_user" name="USER"/>
        <ownedLiteral xmi:id="ucu_lit_role_admin" name="ADMIN"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="ucu_en_PreferenceRisque" name="PreferenceRisque">
        <ownedLiteral xmi:id="ucu_lit_pr_low" name="LOW"/>
        <ownedLiteral xmi:id="ucu_lit_pr_medium" name="MEDIUM"/>
        <ownedLiteral xmi:id="ucu_lit_pr_high" name="HIGH"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="ucu_en_RiskLevel" name="RiskLevel">
        <ownedLiteral xmi:id="ucu_lit_rl_low" name="LOW"/>
        <ownedLiteral xmi:id="ucu_lit_rl_medium" name="MEDIUM"/>
        <ownedLiteral xmi:id="ucu_lit_rl_high" name="HIGH"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="ucu_en_TypeNotification" name="TypeNotification">
        <ownedLiteral xmi:id="ucu_lit_nt_suspended" name="PROJECT_SUSPENDED"/>
        <ownedLiteral xmi:id="ucu_lit_nt_reactivated" name="PROJECT_REACTIVATED"/>
        <ownedLiteral xmi:id="ucu_lit_nt_updated" name="PROJECT_UPDATED"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="ucu_en_RelatedEntityType" name="RelatedEntityType">
        <ownedLiteral xmi:id="ucu_lit_ret_project" name="PROJECT"/>
        <ownedLiteral xmi:id="ucu_lit_ret_investment" name="INVESTMENT"/>
        <ownedLiteral xmi:id="ucu_lit_ret_report" name="REPORT"/>
        <ownedLiteral xmi:id="ucu_lit_ret_payout" name="PAYOUT"/>
        <ownedLiteral xmi:id="ucu_lit_ret_user" name="USER"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Enumeration" xmi:id="ucu_en_StatutPayout" name="StatutPayout">
        <ownedLiteral xmi:id="ucu_lit_pst_pending" name="PENDING"/>
        <ownedLiteral xmi:id="ucu_lit_pst_ready" name="READY"/>
        <ownedLiteral xmi:id="ucu_lit_pst_processing" name="PROCESSING"/>
        <ownedLiteral xmi:id="ucu_lit_pst_completed" name="COMPLETED"/>
        <ownedLiteral xmi:id="ucu_lit_pst_cancelled" name="CANCELLED"/>
        <ownedLiteral xmi:id="ucu_lit_pst_failed" name="FAILED"/>
      </packagedElement>
    </packagedElement>

    <packagedElement xmi:type="uml:Package" xmi:id="ucu_pkg_domaine" name="Domaine">
      <packagedElement xmi:type="uml:Class" xmi:id="ucu_cls_Utilisateur" name="Utilisateur">
        <ownedAttribute xmi:id="ucu_attr_u_id" name="id" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_u_email" name="email" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_u_role" name="role" visibility="private" type="ucu_en_RoleUtilisateur"/>
        <ownedAttribute xmi:id="ucu_attr_u_isActive" name="isActive" visibility="private" type="ucu_pt_Boolean"/>
        <ownedAttribute xmi:id="ucu_attr_u_deletedAt" name="deletedAt" visibility="private" type="ucu_pt_Date"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="ucu_cls_UserProfile" name="UserProfile">
        <ownedAttribute xmi:id="ucu_attr_up_firstName" name="firstName" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_up_lastName" name="lastName" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_up_phone" name="phone" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_up_riskPref" name="riskPreference" visibility="private" type="ucu_en_PreferenceRisque"/>
        <ownedAttribute xmi:id="ucu_attr_up_prefCats" name="preferredCategories" visibility="private" type="ucu_pt_String" isMultivalued="true"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="ucu_cls_AiAnalysis" name="AiAnalysis">
        <ownedAttribute xmi:id="ucu_attr_ai_riskScore" name="riskScore" visibility="private" type="ucu_pt_Number"/>
        <ownedAttribute xmi:id="ucu_attr_ai_riskLevel" name="riskLevel" visibility="private" type="ucu_en_RiskLevel"/>
        <ownedAttribute xmi:id="ucu_attr_ai_successProbability" name="successProbability" visibility="private" type="ucu_pt_Number"/>
        <ownedAttribute xmi:id="ucu_attr_ai_analyzedAt" name="analyzedAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_ai_reportSummary" name="report.summary" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_ai_advantages" name="report.advantages" visibility="private" type="ucu_pt_String" isMultivalued="true"/>
        <ownedAttribute xmi:id="ucu_attr_ai_disadvantages" name="report.disadvantages" visibility="private" type="ucu_pt_String" isMultivalued="true"/>
        <ownedAttribute xmi:id="ucu_attr_ai_improvements" name="report.improvements" visibility="private" type="ucu_pt_String" isMultivalued="true"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="ucu_cls_Projet" name="Projet">
        <ownedAttribute xmi:id="ucu_attr_p_id" name="id" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_p_title" name="title" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_p_description" name="description" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_p_category" name="category" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_p_fundingGoal" name="fundingGoal" visibility="private" type="ucu_pt_Number"/>
        <ownedAttribute xmi:id="ucu_attr_p_currentFunding" name="currentFunding" visibility="private" type="ucu_pt_Number"/>
        <ownedAttribute xmi:id="ucu_attr_p_status" name="status" visibility="private" type="ucu_en_StatutProjet"/>
        <ownedAttribute xmi:id="ucu_attr_p_creatorId" name="creatorId" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_p_startAt" name="startAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_p_deadline" name="deadline" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_p_rejectionReason" name="rejectionReason" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_p_rejectedBy" name="rejectedBy" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_p_rejectedAt" name="rejectedAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_p_isArchived" name="isArchived" visibility="private" type="ucu_pt_Boolean"/>
        <ownedAttribute xmi:id="ucu_attr_p_isCreatorDeleted" name="isCreatorDeleted" visibility="private" type="ucu_pt_Boolean"/>
        <ownedAttribute xmi:id="ucu_attr_p_publishedAt" name="publishedAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_p_fundedAt" name="fundedAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_p_aiAnalysis" name="aiAnalysis" visibility="private" type="ucu_cls_AiAnalysis"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="ucu_cls_Payout" name="Payout">
        <ownedAttribute xmi:id="ucu_attr_po_id" name="id" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_po_projectId" name="projectId" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_po_creatorId" name="creatorId" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_po_amount" name="amount" visibility="private" type="ucu_pt_Number"/>
        <ownedAttribute xmi:id="ucu_attr_po_status" name="status" visibility="private" type="ucu_en_StatutPayout"/>
        <ownedAttribute xmi:id="ucu_attr_po_provider" name="provider" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_po_providerTransferId" name="providerTransferId" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_po_bankDetails" name="bankDetails" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_po_bankDetailsProvidedAt" name="bankDetailsProvidedAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_po_notes" name="notes" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_po_failureReason" name="failureReason" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_po_transferInitiatedAt" name="transferInitiatedAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_po_completedAt" name="completedAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_po_failedAt" name="failedAt" visibility="private" type="ucu_pt_Date"/>
        <ownedAttribute xmi:id="ucu_attr_po_cancelledAt" name="cancelledAt" visibility="private" type="ucu_pt_Date"/>
      </packagedElement>

      <packagedElement xmi:type="uml:Class" xmi:id="ucu_cls_Notification" name="Notification">
        <ownedAttribute xmi:id="ucu_attr_n_id" name="id" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_n_userId" name="userId" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_n_type" name="type" visibility="private" type="ucu_en_TypeNotification"/>
        <ownedAttribute xmi:id="ucu_attr_n_title" name="title" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_n_message" name="message" visibility="private" type="ucu_pt_String"/>
        <ownedAttribute xmi:id="ucu_attr_n_read" name="read" visibility="private" type="ucu_pt_Boolean"/>
        <ownedAttribute xmi:id="ucu_attr_n_relatedEntityId" name="relatedEntityId" visibility="private" type="ucu_pt_ObjectId"/>
        <ownedAttribute xmi:id="ucu_attr_n_relatedEntityType" name="relatedEntityType" visibility="private" type="ucu_en_RelatedEntityType"/>
      </packagedElement>
    </packagedElement>

    <packagedElement xmi:type="uml:Package" xmi:id="ucu_pkg_externes" name="Externes">
      <packagedElement xmi:type="uml:Class" xmi:id="ucu_cls_OrchestrateurAnalyseRisque" name="Orchestrateur_Analyse_Risque"/>
    </packagedElement>

  </uml:Model>
</xmi:XMI>
