@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Traiter signalements » (admin)
' Alignement : `backend/routes/api/adminRoutes.js`, `backend/services/reportService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Admin : lister / traiter signalements »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class AdminRoutes <<controller>> {
  +GET /api/admin/reports(status?, limit?)
  +POST /api/admin/reports/:id/resolve(resolution, actionOnProject?, actionOnComment?, status?)
}

class RequireAdmin <<middleware>> {
  +requireAdmin()
}

class ReportService <<service>> {
  +listAdminReports({ status?, limit? })
  +resolveReport({ adminId, reportId, resolution, ... })
}

class Report <<model>> {
  +status
  +resolvedBy
  +resolution
}

AdminRoutes ..> RequireAdmin
AdminRoutes ..> ReportService
ReportService ..> Report

@enduml
