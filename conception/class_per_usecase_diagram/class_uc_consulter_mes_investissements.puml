@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Consulter mes contributions »
' Alignement : `backend/routes/api/investmentRoutes.js`, `backend/services/investmentService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Consulter mes contributions »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class InvestmentRoutes <<controller>> {
  +GET /api/investments/mine(limit?)
}

class InvestmentService <<service>> {
  +listMyInvestments(userId, { limit? })
}

class Investment <<model>> {
  +projectId
  +amount
  +status
}

InvestmentRoutes ..> InvestmentService
InvestmentService ..> Investment

@enduml
