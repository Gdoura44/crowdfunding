@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Renvoyer après rejet »
' Alignement : `backend/routes/api/projectRoutes.js`, `backend/services/projectService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Renvoyer après rejet »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class ProjectRoutes <<controller>> {
  +PUT /api/projects/:id/resubmit(données)
}

class ProjectService <<service>> {
  +resubmitRejectedProject(creatorId, projectId, changes)
}

class Project <<model>> {
  +status
  +rejectionReason
}

ProjectRoutes ..> ProjectService
ProjectService ..> Project

@enduml
