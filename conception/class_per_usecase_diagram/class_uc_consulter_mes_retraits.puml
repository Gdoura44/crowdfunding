@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Consulter mes retraits »
' Alignement : `backend/routes/api/payoutRoutes.js`, `backend/services/payoutService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Consulter mes retraits »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class PayoutRoutes <<controller>> {
  +GET /api/payouts/mine(limit?)
  +GET /api/payouts/:id()
}

class PayoutService <<service>> {
  +listMyPayouts(userId, { limit? })
  +getMyPayout(userId, payoutId)
}

class Payout <<model>> {
  +amount
  +status
  +projectId
}

PayoutRoutes ..> PayoutService
PayoutService ..> Payout

@enduml
