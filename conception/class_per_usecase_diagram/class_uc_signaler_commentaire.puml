@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Signaler un commentaire »
' Alignement : `backend/routes/api/reportRoutes.js`, `backend/services/reportService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Signaler un commentaire »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class ReportRoutes <<controller>> {
  +POST /api/reports/comments(projectId, commentId, type, description?)
}

class ReportService <<service>> {
  +createCommentReport({ reporterId, projectId, commentId, type, description? })
}

class Report <<model>> {
  +commentId
  +projectId
  +status
}

ReportRoutes ..> ReportService
ReportService ..> Report

@enduml
