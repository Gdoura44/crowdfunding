@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Rechercher des projets »
' Alignement : `backend/routes/api/projectRoutes.js`, `backend/services/projectService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Rechercher des projets »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class ProjectRoutes <<controller>> {
  +GET /api/projects/search(query...)
}

class ProjectService <<service>> {
  +searchPublicProjects(params)
}

class Project <<model>> {
  +title
  +category
  +status
}

ProjectRoutes ..> ProjectService
ProjectService ..> Project

@enduml
