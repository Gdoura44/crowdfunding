@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Discuter avec assistant » (projet)
' Alignement : `backend/routes/api/chatbotRoutes.js`, `backend/services/geminiChatService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Assistant chat (projet) »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class ChatbotRoutes <<controller>> {
  +POST /api/projects/:id/chat(question)
}

class Project <<model>> {
  +title
  +description
  +status
  +fundingGoal
  +currentFunding
}

class GeminiChatService <<service>> {
  +generateGeminiText(prompt)
}

ChatbotRoutes ..> Project : findById (handler)
ChatbotRoutes ..> GeminiChatService

note bottom of ChatbotRoutes
  Chemin API : voir `frontend/src/api/paths.js`.\n
  Réponse `{ answer, mode }` (IA ou secours).
end note

@enduml
