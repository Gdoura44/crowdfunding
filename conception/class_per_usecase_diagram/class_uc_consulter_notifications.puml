@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Consulter notifications »
' Alignement : `backend/routes/api/notificationRoutes.js`, `backend/services/notificationService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Consulter notifications »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class NotificationRoutes <<controller>> {
  +GET /api/notifications/(limit?)
  +PATCH /api/notifications/:id/read()
  +PUT /api/notifications/:id/read()
}

class NotificationService <<service>> {
  +listUserNotifications(userId, { limit? })
  +markAsRead(userId, notificationId)
}

class Notification <<model>> {
  +userId
  +type
  +read
  +relatedEntityId
}

NotificationRoutes ..> NotificationService
NotificationService ..> Notification

@enduml
