@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Publier projet » (admin)
' Alignement : `backend/routes/api/adminRoutes.js`, `backend/services/adminProjectService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Admin : publier projet »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class AdminRoutes <<controller>> {
  +POST /api/admin/projects/:id/publish()
}

class RequireAdmin <<middleware>> {
  +requireAdmin()
}

class AdminProjectService <<service>> {
  +publishProject({ adminId, projectId })
}

class Project <<model>> {
  +status
  +publishedAt
}

AdminRoutes ..> RequireAdmin
AdminRoutes ..> AdminProjectService
AdminProjectService ..> Project

@enduml
