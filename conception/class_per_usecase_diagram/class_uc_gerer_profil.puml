@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Gérer profil »
' Alignement : `backend/routes/api/userRoutes.js`, `backend/services/auditService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Gérer profil »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class UserRoutes <<controller>> {
  +GET /api/users/profile()
  +PUT /api/users/profile(données)
}

class AuditService <<service>> {
  +writeAudit({ actorId, action, targetType, ... })
}

class User <<model>> {
  +email
  +profile
}

class UserProfile <<embedded>> {
  +firstName
  +lastName
  +phone
  +riskPreference
  +preferredCategories[]
}

UserRoutes ..> User
UserRoutes ..> AuditService
User *-- UserProfile

@enduml
