@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Mes signalements »
' Alignement : `backend/routes/api/reportRoutes.js`, `backend/services/reportService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Mes signalements »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class ReportRoutes <<controller>> {
  +GET /api/reports/mine(limit?)
}

class ReportService <<service>> {
  +listMyReports(userId, { limit? })
}

class Report <<model>> {
  +reporterId
  +status
  +resolution
}

ReportRoutes ..> ReportService
ReportService ..> Report

@enduml
