@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Commenter »
' Alignement : `backend/routes/api/projectRoutes.js`, modèle `Comment`
' ==========================================================

title Diagramme de classes participantes — UC « Publier commentaire »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class ProjectRoutes <<controller>> {
  +POST /api/projects/:id/comments(content)
  +GET /api/projects/:id/comments()
}

class ProjectService <<service>> {
  +getProjectById(projectId, viewerUserId?)
}

class Comment <<model>> {
  +projectId
  +userId
  +content
  +authorLabel
}

ProjectRoutes ..> ProjectService
ProjectRoutes ..> Comment

note bottom of ProjectRoutes
  Rate-limit dédié aux POST commentaires.
end note

@enduml
