@startuml
' ==========================================================
' Diagramme de classes participantes — UC « Relancer analyse » (admin)
' Alignement : `backend/routes/api/adminRoutes.js`, `backend/services/adminProjectService.js`
' ==========================================================

title Diagramme de classes participantes — UC « Admin : relancer analyse IA »
left to right direction
skinparam dpi 160
skinparam shadowing false
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam wrapWidth 240

class AdminRoutes <<controller>> {
  +POST /api/admin/projects/:id/retry-ai()
}

class RequireAdmin <<middleware>> {
  +requireAdmin()
}

class AdminProjectService <<service>> {
  +retryAiAnalysis({ adminId, projectId })
}

class Project <<model>> {
  +aiStatus
  +aiJobId
}

AdminRoutes ..> RequireAdmin
AdminRoutes ..> AdminProjectService
AdminProjectService ..> Project

@enduml
