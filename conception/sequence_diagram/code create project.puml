@startuml
title Séquence métier — Créer un projet (Project)
' ------------------------------------------------------------------
' Style impression A4 (PFE FSEG) — lisibilité : polices ~11–12 pt visibles,
' DPI 240, retour à la ligne des messages. Inclure juste après la ligne title.
' Export PNG pour Word/LaTeX : viser largeur <= zone utile A4 (~17 cm).
' ------------------------------------------------------------------
scale max 1550 width
skinparam dpi 240
skinparam shadowing false
skinparam handwritten false
skinparam HyperlinkUnderline false

skinparam defaultFontSize 12
skinparam titleFontSize 16
skinparam ArrowFontSize 11
skinparam arrowThickness 1.25
skinparam wrapWidth 220
skinparam NoteFontSize 10
skinparam LegendFontSize 10
skinparam footerFontSize 10
skinparam headerFontSize 10

skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 14
skinparam BoxPadding 8
skinparam LifeLineBorderColor #444444
skinparam LifeLineBackgroundColor #FEFEFE
skinparam ArrowColor #222222
skinparam ActorBorderColor #222222
skinparam ActorBackgroundColor #EEF6FF
skinparam ParticipantBorderColor #333333
skinparam ParticipantBackgroundColor #FFFFFF

skinparam DatabaseBackgroundColor #F8F8F8
skinparam EntityBackgroundColor #F8FFF8
skinparam ControlBackgroundColor #FFF8F0
skinparam BoundaryBackgroundColor #F5F5FF
actor "Utilisateur" as user
boundary "GestionProjet" as UI
control "Contrôleur" as Svc
entity "Base de données" as DB
queue "BullMQ : risk-analysis" as Queue
participant "RiskAnalysisWorkflow (n8n)" as n8n
participant "API Gemini" as Gemini

user -> UI: Remplir les détails du projet et enregistrer en brouillon
UI -> Svc: POST /api/projects\n{ title, description, category, fundingGoal, startAt, deadline }

Svc -> Svc: Validation Zod + projectService\n(startAt ≥ J+7,\n deadline ≥ startAt + 30 jours ; deadline > startAt)

alt erreurs de validation (400)
  Svc --> UI: 400 messages métier (dates / palier de financement)
else
  Svc -> DB: Créer Project (DRAFT, startAt, deadline, aiStatus=PENDING, creatorId, …)
  Svc -> DB: Notification (in-app) type PROJECT_CREATED\n(+ e-mail sans bloquer, selon la politique)
  Svc -> UI: 201 { project }
  UI -> user: Brouillon enregistré (modifiable)

  user -> UI: Soumettre le projet à l’analyse IA
  UI -> Svc: POST /api/projects/:id/submit-for-ai
  Svc -> DB: transitionProjectStatus(project, AWAITING_AI,\n action=\"SUBMIT_FOR_AI\")\n+ aiStatus=PENDING ; aiQueuedAt=now ; aiJobId=\"\" ; aiLastError=\"\"
  Svc -> DB: Notification (in-app) type PROJECT_SUBMITTED\n(+ e-mail sans bloquer, selon la politique)

  note right of Svc
    Déclenchement asynchrone — ne pas attendre la fin (l’analyse se fait en arrière-plan)
  end note
Svc -> Queue: enqueueRiskAnalysisJob(project)\n(données = buildRiskPayload(project))
  Svc -> UI: 200 { message, project }
  UI -> user: Projet soumis, analyse en cours

  ' Traitement en arrière-plan (consumer BullMQ → n8n)
  Queue -> n8n: (consumer) traite le job risk-analysis
n8n -> Svc: POST /internal/run-risk-analysis { ...données }
  Svc -> Gemini: POST /v1beta/models/{flash-model}:generateContent (prompt)
  Gemini -> Svc: JSON { successProbability, report, sourcesUsed, meta }
  alt Analyse terminée (pas de blocage automatique)
    Svc -> DB: aiStatus=COMPLETED ; aiAnalysis=... ; analyzedAt=now\ntransitionProjectStatus(project, UNDER_REVIEW)
  else Blocage automatique (règles heuristiques)
    Svc -> DB: aiStatus=COMPLETED ; aiAnalysis=... ; analyzedAt=now\ntransitionProjectStatus(project, REJECTED)\n+ rejectionReason + rejectedAt (auto)
  end
  Svc -> n8n: 200 { ok:true, project:{...} }
  n8n -> n8n: Journaliser le succès

  alt failure (n8n retries exhausted / Gemini error)
    Svc -> DB: Erreur transitoire: aiNextRetryAt + retry auto\nou erreur non transitoire: aiStatus FAILED
    Svc -> DB: Créer FailedWorkflowEvent { projectId, workflowType="risk-analysis", error, données }
  end
end
@enduml
