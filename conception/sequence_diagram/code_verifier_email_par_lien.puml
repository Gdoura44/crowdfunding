@startuml
title Séquence métier — Vérifier le compte par lien e-mail
' ------------------------------------------------------------------
' Style impression A4 (PFE FSEG)
' ------------------------------------------------------------------
scale max 1550 width
skinparam dpi 240
skinparam shadowing false
skinparam handwritten false
skinparam HyperlinkUnderline false

skinparam defaultFontSize 12
skinparam titleFontSize 16
skinparam ArrowFontSize 11
skinparam arrowThickness 1.25
skinparam wrapWidth 220
skinparam NoteFontSize 10

skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 14
skinparam BoxPadding 8
skinparam LifeLineBorderColor #444444
skinparam LifeLineBackgroundColor #FEFEFE
skinparam ArrowColor #222222
skinparam ActorBorderColor #222222
skinparam ActorBackgroundColor #EEF6FF
skinparam ParticipantBorderColor #333333
skinparam ParticipantBackgroundColor #FFFFFF

actor "Utilisateur" as user
boundary "Lien e-mail / navigateur" as UI
control "Contrôleur" as Svc
entity "Base de données" as DB

user -> UI: Cliquer sur le lien de vérification\n(GET avec ?token=...)
UI -> Svc: GET /api/auth/verify-email?token=...

Svc -> DB: Charger utilisateur par hash du token
DB --> Svc: user (ou absent)

alt token valide et non expiré
  Svc -> DB: Activer le compte + invalider jetons de vérification
  Svc --> UI: 200 { message, status: "VERIFIED" }
  UI --> user: Message de succès
else lien déjà utilisé / expiré / compte déjà vérifié
  Svc --> UI: 200 { message, status }
  UI --> user: Message explicatif (sans divulguer l’existence du compte)
end

@enduml
