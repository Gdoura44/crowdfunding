@startuml
title Séquence métier — Modifier un projet (Project)
' ------------------------------------------------------------------
' Style impression A4 (PFE FSEG) — lisibilité : polices ~11–12 pt visibles,
' DPI 240, retour à la ligne des messages. Inclure juste après la ligne title.
' Export PNG pour Word/LaTeX : viser largeur <= zone utile A4 (~17 cm).
' ------------------------------------------------------------------
scale max 1550 width
skinparam dpi 240
skinparam shadowing false
skinparam handwritten false
skinparam HyperlinkUnderline false

skinparam defaultFontSize 12
skinparam titleFontSize 16
skinparam ArrowFontSize 11
skinparam arrowThickness 1.25
skinparam wrapWidth 220
skinparam NoteFontSize 10
skinparam LegendFontSize 10
skinparam footerFontSize 10
skinparam headerFontSize 10

skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 14
skinparam BoxPadding 8
skinparam LifeLineBorderColor #444444
skinparam LifeLineBackgroundColor #FEFEFE
skinparam ArrowColor #222222
skinparam ActorBorderColor #222222
skinparam ActorBackgroundColor #EEF6FF
skinparam ParticipantBorderColor #333333
skinparam ParticipantBackgroundColor #FFFFFF

skinparam DatabaseBackgroundColor #F8F8F8
skinparam EntityBackgroundColor #F8FFF8
skinparam ControlBackgroundColor #FFF8F0
skinparam BoundaryBackgroundColor #F5F5FF
actor "Utilisateur" as user
boundary "GestionProjet" as UI
control "Contrôleur" as Svc
entity "Base de données" as DB

user -> UI: Ouvrir le formulaire de modification
UI -> Svc: GET /api/projects/:id/edit
Svc -> DB: Trouver le projet par id et creatorId (user.id)
DB --> Svc: project

alt projet existe et utilisateur est le créateur
  alt project.status éditable (DRAFT / UNDER_REVIEW / REJECTED)
    Svc --> UI: project data
    UI --> user: Afficher le formulaire

    user -> UI: Modifier { title, description, category, fundingGoal, startAt, deadline }

    alt project.status == "REJECTED"
      UI -> Svc: PUT /api/projects/:id/resubmit { champs mis à jour }
    else
      UI -> Svc: PUT /api/projects/:id { champs mis à jour }
    end

    Svc -> Svc: Validation Zod + règles métier
    note right of Svc
      Même règles que la création :
      - startAt ≥ J+7
      - deadline ≥ startAt + 30 jours
      - deadline > startAt (jours calendaires)
    end note

    alt validation échoue
      Svc --> UI: 400 « Validation échouée » (details.fieldErrors)
      UI --> user: Afficher erreurs par champ
    else
      Svc -> DB: Mettre à jour Project (champs + dates normalisées)

      alt project.status était REJECTED
        Svc -> DB: transitionProjectStatus(project, DRAFT, action=\"EDIT_REJECTED_PROJECT\")\n+ vider les champs de rejet
      end

      alt project.status == UNDER_REVIEW
        Svc -> DB: status -> AWAITING_AI (action=\"EDIT_PROJECT_RERUN_AI\")\naiStatus -> PENDING\naiAnalysisRetries=0 ; aiLastError=\"\" ; aiAnalysis=undefined
        Svc -> Svc: enqueueRiskAnalysisJob(project) (sans bloquer)
      end

      Svc -> DB: writeAudit(action=\"EDIT_PROJECT\", details:{ fields })
      Svc -> DB: Notification PROJECT_UPDATED (+ e-mail sans bloquer)
      Svc --> UI: 200 { project, message: \"Projet mis à jour.\" }
      UI --> user: Message succès + retour page Project
    end
  else project.status non éditable
    Svc --> UI: 403 « Modification impossible dans l’état actuel du projet. »
    UI --> user: Modifier impossible à ce stade
  end
else
  Svc --> UI: 404 « Projet introuvable. »
end
@enduml
