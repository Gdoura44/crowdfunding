@startuml
title Séquence métier — Signaler un commentaire
' ------------------------------------------------------------------
' Style impression A4 (PFE FSEG)
' ------------------------------------------------------------------
scale max 1550 width
skinparam dpi 240
skinparam shadowing false
skinparam defaultFontSize 12
skinparam titleFontSize 16
skinparam ArrowFontSize 11
skinparam arrowThickness 1.25
skinparam wrapWidth 220
skinparam responseMessageBelowArrow true
skinparam linetype ortho

actor Utilisateur as user
boundary "Fiche projet" as UI
control "API (ReportRoutes)" as API
control "Limiteur de débit" as RL
entity "Base de données" as DB
queue "BullMQ : send-email" as Queue

user -> UI: Cliquer "Signaler" + saisir la raison
UI -> API: POST /api/reports/comments { projectId, commentId, type, description }

API -> RL: Vérifier limite (6/10 min)
alt limite dépassée
  RL --> API: bloqué
  API --> UI: 429 Trop de signalements
else ok
  RL --> API: ok
  API -> DB: Vérifier Project existe
  API -> DB: Vérifier Comment existe (non supprimé) + user != comment.userId
  alt self-report
    API --> UI: 400 Interdit (son propre commentaire)
  else ok
    API -> DB: Vérifier doublon (reporterId, commentId, type) status in PENDING/RESOLVED
    alt doublon
      API --> UI: 409 Déjà signalé
    else nouveau
      API -> DB: Créer Report(status=PENDING, commentId, projectId, ...)
      API -> DB: Créer Notifications NEW_REPORT pour admins
      API -> Queue: enqueueEmailForNotifications(adminNotifs)
      API --> UI: 201 Signalement envoyé
      UI --> user: Message "Merci, un admin va examiner"
    end
  end
end

@enduml

